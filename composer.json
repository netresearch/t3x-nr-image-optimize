{
    "name": "netresearch/nr-image-optimize",
    "description": "On-demand image optimization for TYPO3 with processed delivery, WebP and AVIF variants, and responsive srcset ViewHelpers.",
    "type": "typo3-cms-extension",
    "license": "GPL-3.0-or-later",
    "keywords": [
        "typo3",
        "image",
        "optimization",
        "webp",
        "avif",
        "responsive",
        "srcset"
    ],
    "authors": [
        {
            "name": "Team der Netresearch DTT GmbH",
            "homepage": "https://www.netresearch.de"
        }
    ],
    "homepage": "https://extensions.typo3.org/extension/nr_image_optimize",
    "support": {
        "issues": "https://github.com/netresearch/t3x-nr-image-optimize/issues",
        "source": "https://github.com/netresearch/t3x-nr-image-optimize"
    },
    "config": {
        "bin-dir": ".build/bin",
        "vendor-dir": ".build/vendor",
        "discard-changes": true,
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform-check": false,
        "allow-plugins": {
            "a9f/fractor-extension-installer": true,
            "captainhook/hook-installer": true,
            "infection/extension-installer": true,
            "phpstan/extension-installer": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "require": {
        "php": ">=8.2",
        "typo3/cms-core": "^13.4 || ^14.0",
        "typo3/cms-extbase": "^13.4 || ^14.0",
        "typo3/cms-fluid": "^13.4 || ^14.0",
        "intervention/image": "^3.11 || ^4.0"
    },
    "require-dev": {
        "netresearch/typo3-ci-workflows": "^1.1"
    },
    "suggest": {
        "christophlehmann/imageoptimizer": "Optimize uploaded/processed images with binaries of your choice"
    },
    "autoload": {
        "psr-4": {
            "Netresearch\\NrImageOptimize\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Netresearch\\NrImageOptimize\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "nr_image_optimize",
            "web-dir": ".build/public"
        },
        "branch-alias": {
            "dev-main": "2.2.x-dev"
        }
    },
    "scripts": {
        "ci:cgl": [
            "php-cs-fixer fix --config Build/.php-cs-fixer.dist.php --diff --verbose --cache-file .build/.php-cs-fixer.cache"
        ],
        "ci:rector": [
            "rector process --config Build/rector.php"
        ],
        "ci:fractor": [
            "fractor process --config Build/fractor.php"
        ],
        "ci:test:php:cgl": [
            "@ci:cgl --dry-run"
        ],
        "ci:test:php:lint": [
            "phplint --configuration Build/.phplint.yml"
        ],
        "ci:test:php:unit": [
            "phpunit --configuration Build/UnitTests.xml"
        ],
        "ci:test:php:unit:coverage": [
            "@putenv XDEBUG_MODE=coverage",
            "phpunit --configuration Build/UnitTests.xml --coverage-html .build/coverage/"
        ],
        "ci:test:php:acceptance": [
            "phpunit --configuration Build/AcceptanceTests.xml"
        ],
        "ci:test:php:functional": [
            "phpunit --configuration Build/FunctionalTests.xml"
        ],
        "ci:test:php:fuzz": [
            "phpunit --configuration Build/FuzzTests.xml --no-coverage"
        ],
        "ci:test:php:mutation": [
            "@putenv XDEBUG_MODE=coverage",
            "infection --configuration=infection.json5 --threads=4 --no-progress --show-mutations"
        ],
        "ci:test:php:phpstan": [
            "phpstan analyze --configuration Build/phpstan.neon --memory-limit=-1"
        ],
        "ci:test:php:phpstan:baseline": [
            "phpstan analyze --configuration Build/phpstan.neon --memory-limit=-1 --generate-baseline Build/phpstan-baseline.neon --allow-empty-baseline"
        ],
        "ci:test:php:rector": [
            "@ci:rector --dry-run"
        ],
        "ci:test:php:fractor": [
            "@ci:fractor --dry-run"
        ],
        "ci:test": [
            "@ci:test:php:lint",
            "@ci:test:php:phpstan",
            "@ci:test:php:rector",
            "@ci:test:php:fractor",
            "@ci:test:php:unit",
            "@ci:test:php:cgl"
        ]
    }
}
